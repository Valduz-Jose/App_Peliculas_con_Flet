# Entorno Virtual
venv/
.venv/
env/

# Variables de entorno (¡CRÍTICO! Contiene tus contraseñas)
.env

# Archivos de Python
__pycache__/
*.py[cod]
*$py.class

# Base de datos local (por si usaras SQLite en algún punto)
*.sqlite3
*.db

# Archivos de VS Code
.vscode/

# Distribución / Paquetes
dist/
build/
*.spec

# [NUEVO] Alembic
# No ignoramos la carpeta alembic/ ni el archivo alembic.ini (son necesarios)
# Pero podemos ignorar los archivos de cache y logs de migraciones si lo prefieres
alembic/__pycache__/

# [NUEVO] Archivos temporales de Python
*.log
.pytest_cache/
.coverage

# [NUEVO] Si usas el script migrate.py que crea revisiones automáticas, 
# a veces es mejor no subir las versiones de desarrollo local:
 alembic/versions/*.py 
# (Nota: Solo descomenta la línea anterior si prefieres que cada entorno gestione sus revisiones)